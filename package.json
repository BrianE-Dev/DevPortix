{
  "name": "devportix-app",
  "version": "1.0.0",
  "private": true,
  "description": "devportix node  server",
  "keywords": [
    "server",
    "setup"
  ],
  "license": "ISC",
  "author": "brian-e-dev",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n frontend,backend,portfolio-service,quiz-service -c cyan,green,magenta,yellow \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:portfolio-service\" \"npm run dev:quiz-service\"",
    "dev:frontend": "cd frontend && vite",
    "dev:backend": "nodemon server.js",
    "dev:portfolio-service": "nodemon backend/portfolio.service.js",
    "dev:quiz-service": "nodemon backend/quiz.service.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "nodemon server.js",
    "build": "cd frontend && vite build",
    "lint": "eslint --config frontend/eslint.config.mjs \"frontend/src/**/*.{js,jsx}\"",
    "preview": "cd frontend && vite preview"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dompurify": "^3.3.1",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-rate-limiter": "^1.3.1",
    "file-saver": "^2.0.5",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.0.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "mongodb": "^7.1.0",
    "mongoose": "^9.2.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "nodemon": "^3.1.11",
    "paystack-api": "^2.0.6",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.12.0",
    "react-syntax-highlighter": "^16.1.0",
    "slugify": "^1.6.6",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "vite": "^7.2.4"
  }
}
